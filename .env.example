# 本地运行配置模板
# 复制本文件为 .env 后修改；.env 不会提交到 Git。

# 是否默认把训练 Web 合并挂载到 sameobject_api.py 的同一个端口。
ENABLE_TRAINING_WEB=1

# 识别接口 Key：用于 POST /api/identify/image，请通过 X-API-Key 或 Authorization: Bearer 传递。
SAMEOBJECT_API_KEY=replace-with-a-long-random-api-key

# 管理员 Key：用于 /admin 页面登录和 /api/admin/*，与上面的识别 Key 分开。
TRAINING_WEB_ADMIN_KEY=replace-with-a-different-admin-key

# 初筛阈值：模型高置信度且与用户选择不一致时自动拦截。
TRAINING_WEB_REJECT_CONFIDENCE=0.80
# 训练时是否默认包含“模型和用户一致后自动通过”的样本。
# 1=包含；0=不包含，只训练人工审核通过的样本。管理员页面训练前也可以临时切换。
INCLUDE_AUTO_APPROVED_IN_TRAINING=1

